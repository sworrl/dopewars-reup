; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Dope Wars: Re-Up Edition"
config/version="0.2.0"
config/description="A realistic drug-trade MMO on a real US map. The Wire, not GTA."
; Don't let a single back-gesture kill the app — AppNav closes dialogs first, then confirms exit.
config/quit_on_go_back=false
run/main_scene="res://scenes/loading.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.png"
run/max_fps=0
boot_splash/bg_color=Color(0.03, 0.03, 0.04, 1)
boot_splash/image="res://assets/sprites/ui/boot_art.png"
boot_splash/fullsize=false
boot_splash/use_filter=true
boot_splash/show_image=true

[autoload]

PlayerState="*res://scripts/state/player_state.gd"
Market="*res://scripts/state/market.gd"
Router="*res://scripts/routing/router.gd"
Anim="*res://scripts/util/anim.gd"
Notify="*res://scripts/ui/notify.gd"
AndroidNotify="*res://scripts/util/android_notify.gd"
AppNav="*res://scripts/util/app_nav.gd"
Supa="*res://scripts/net/supa.gd"
Updater="*res://scripts/net/updater.gd"
Comms="*res://scripts/net/comms.gd"
PhoneFrame="*res://scripts/ui/phone_frame.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=2340
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
; Multiplies all UI element sizes (fonts, button heights, margins) by this factor.
; 1.3 hits Material/HIG touch targets at 480dpi xxhdpi without overflowing the viewport.
window/stretch/scale=1.3
; 6 = Sensor: follow the device in all orientations (full landscape + portrait support).
window/handheld/orientation=6
; Adaptive vsync — pace to display, but allow uncapped frames when display refresh is high
; (Pixel 10 Pro XL is LTPO 1-120Hz). 0 = disabled, 1 = enabled, 2 = adaptive, 3 = mailbox.
window/vsync/vsync_mode=3

[gui]

theme/custom_font="res://assets/fonts/PlusJakartaSans-SemiBold.ttf"
theme/default_font_size=32
; Touch drag-to-scroll: with deadzone 0 a ScrollContainer never steals a drag that starts on a child
; button, so only the scrollbar scrolls (the Pixel symptom). A small deadzone lets content-area drags
; scroll everywhere. Applies to every ScrollContainer in the game.
common/default_scroll_deadzone=24

[physics]

common/physics_ticks_per_second=120
common/max_physics_steps_per_frame=8

[input]

pan_left={
"deadzone": 0.2,
"events": [Object(InputEventJoypadMotion,"resource_local_to_scene":false,"resource_name":"","device":-1,"axis":0,"axis_value":-1.0,"script":null)
, Object(InputEventJoypadButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"button_index":13,"pressure":0.0,"pressed":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":65,"key_label":0,"unicode":97,"location":0,"echo":false,"script":null)
]
}
pan_right={
"deadzone": 0.2,
"events": [Object(InputEventJoypadMotion,"resource_local_to_scene":false,"resource_name":"","device":-1,"axis":0,"axis_value":1.0,"script":null)
, Object(InputEventJoypadButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"button_index":14,"pressure":0.0,"pressed":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":68,"key_label":0,"unicode":100,"location":0,"echo":false,"script":null)
]
}
pan_up={
